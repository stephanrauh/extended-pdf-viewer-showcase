{
  "name": "pdf-showcase",
  "version": "28.0.0-alpha.0",
  "scripts": {
    "ng": "ng",
    "preinstall": "node ./build-tools/check-ignore-scripts.js",
    "install": "npm install --ignore-scripts && npm update --save --ignore-scripts && npm audit fix --ignore-scripts && ./build-tools/search-for-shai-hulud.sh --full && npm rebuild esbuild",
    "update": "npm update --save --ignore-scripts && npm audit fix --ignore-scripts && ./build-tools/search-for-shai-hulud.sh --full && npm rebuild esbuild",
    "prebuild": "node extract-versions.js && rm -rf .angular",
    "build": "ng build --configuration production",
    "start": "ng s --configuration production --open",
    "postbuild": "rm -r -f dist/pdf-showcase/browser/assets/pdfs/under-copyright && rm -f dist/pdf-showcase/browser/stats.json",
    "release": "npm run build && cp ftp/.htaccess dist/pdf-showcase/browser && cd ftp && npx tsx upload.ts",
    "test": "ng test",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --config=e2e/playwright.config.ts --ui",
    "test:e2e:report": "playwright show-report e2e/.playwright-report",
    "test:e2e:install": "playwright install chromium",
    "lint": "ng lint",
    "full": "cd ../ngx-extended-pdf-viewer && npm run build:base && npm run build:lib && cd ../extended-pdf-viewer-showcase && npm run prebuild && ng s --host 0.0.0.0",
    "ts": "cd ../ngx-extended-pdf-viewer && npm run build:lib && cd ../extended-pdf-viewer-showcase && npm run prebuild && ng s --host 0.0.0.0",
    "build:stats": "ng build --stats-json",
    "analyze": "webpack-bundle-analyzer dist/pdf-showcase/browser/stats.json"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^22.0.0",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.1",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-browser-dynamic": "^22.0.1",
    "@angular/platform-server": "^22.0.1",
    "@angular/router": "^22.0.1",
    "@angular/ssr": "^22.0.1",
    "@standard-schema/spec": "^1.1.0",
    "angular2-smart-table": "^4.1.1",
    "esbuild": "^0.27.7",
    "ngx-extended-pdf-viewer": "^28.0.1",
    "ngx-markdown": "^21.3.0",
    "ngx-scrollbar": "^19.1.5",
    "pdf-lib": "^1.17.1",
    "prismjs": "^1.30.0",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "web-animations-js": "^2.3.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^22.0.1",
    "@angular/cli": "^22.0.1",
    "@angular/compiler-cli": "^22.0.1",
    "@angular/language-service": "^22.0.1",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.21",
    "angular-eslint": "^22.0.0",
    "autoprefixer": "^10.5.0",
    "basic-ftp": "^6.0.1",
    "brotli": "^1.3.3",
    "dotenv": "^17.4.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-preset-angular": "^16.2.0",
    "jsdom": "^29.1.1",
    "node-dir": "^0.1.17",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.0",
    "typescript-eslint": "^8.61.1",
    "webpack-bundle-analyzer": "^5.3.0"
  },
  "overrides": {
    "ajv": ">=8.18.0",
    "angular2-smart-table": {
      "@angular/forms": "^22.0.0",
      "@angular/core": "^22.0.0",
      "@angular/common": "^22.0.0"
    },
    "ngx-markdown": {
      "@angular/core": "^22.0.0",
      "@angular/common": "^22.0.0",
      "@angular/platform-browser": "^22.0.0"
    },
    "jest-preset-angular": {
      "@angular/core": "^22.0.0",
      "@angular/compiler-cli": "^22.0.0",
      "@angular-devkit/build-angular": "^22.0.0",
      "@angular/platform-browser": "^22.0.0",
      "@angular/platform-browser-dynamic": "^22.0.0",
      "jest": "^30.0.0"
    },
    "uuid": ">=11.1.1",
    "webpack-dev-server": ">=5.2.4"
  }
}
